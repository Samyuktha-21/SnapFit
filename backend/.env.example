# Copy this file to `.env` and fill in values for local development.
# On Render, set these in the dashboard under Environment instead.

# Port the server listens on. Render injects its own PORT automatically,
# so you usually only need this locally.
PORT=3001

# The exact origin of your deployed frontend, used for CORS.
# Example: https://snapfit.vercel.app
# Leave unset to allow all origins (fine for local dev / demo, not production).
FRONTEND_URL=
